results/symbolic_rank/*.log

# AWS lifecycle and heartbeat markers (ephemeral)
**/heartbeat.json
**/instance_heartbeat.json
**/aws_completion.json

# Computation logs in results/ (large, regeneratable from S3)
results/**/live.log
results/**/full.log
results/sc_*.log
results/targeted_*.log
